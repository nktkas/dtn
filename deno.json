{
  "name": "@nktkas/dtn",
  "version": "1.0.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts"
  },
  "imports": {
    "@deno/cache-dir": "jsr:@deno/cache-dir@^0.27",
    "@deno/graph": "jsr:@deno/graph@^0.108",
    "@std/cli/parse-args": "jsr:@std/cli@^1/parse-args",
    "@std/fmt/colors": "jsr:@std/fmt@^1/colors",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "oxc-parser": "npm:oxc-parser@^0.134",
    "oxc-walker": "npm:oxc-walker@^1",
    "sort-package-json": "npm:sort-package-json@^4",
    "type-fest": "npm:type-fest@^5"
  },
  "tasks": {
    "test": "deno test -A",
    "test:integration": "DTN_INTEGRATION=1 deno test -A",
    "check": "deno fmt --check && deno lint && deno check --doc"
  },
  "fmt": {
    "lineWidth": 120
  },
  "publish": {
    "exclude": [".github", "tests"]
  },
  "lock": false
}
